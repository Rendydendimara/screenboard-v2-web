VITE_API_BASE_URL=http://localhost:8080
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_MIXPANEL_TOKEN=your_mixpanel_token
VITE_PORT=8081
# Analytics Settings
# Set to 'true' to enable analytics in development mode (default: disabled in dev)
VITE_ENABLE_ANALYTICS_IN_DEV=false
# AI Insights Feature Flag
# Set to 'true' to show App Profile & Competitors sections (default: hidden until release)
VITE_ENABLE_AI_INSIGHTS=false
